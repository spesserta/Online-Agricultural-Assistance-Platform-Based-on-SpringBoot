<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.GaoxiaoDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.GaoxiaoEntity" id="gaoxiaoMap">
        <result property="gaoxiaomingcheng" column="gaoxiaomingcheng"/>
        <result property="mima" column="mima"/>
        <result property="gaoxiaodizhi" column="gaoxiaodizhi"/>
        <result property="gaoxiaodianhua" column="gaoxiaodianhua"/>
        <result property="touxiang" column="touxiang"/>
        <result property="gaoxiaojianjie" column="gaoxiaojianjie"/>
        <result property="money" column="money"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.GaoxiaoVO" >
		SELECT * FROM gaoxiao  gaoxiao         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.GaoxiaoVO" >
		SELECT  gaoxiao.* FROM gaoxiao  gaoxiao 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.GaoxiaoView" >

		SELECT  gaoxiao.* FROM gaoxiao  gaoxiao 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.GaoxiaoView" >
		SELECT * FROM gaoxiao  gaoxiao <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	


</mapper>
