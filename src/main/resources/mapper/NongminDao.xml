<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dao.NongminDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.NongminEntity" id="nongminMap">
        <result property="nongminzhanghao" column="nongminzhanghao"/>
        <result property="mima" column="mima"/>
        <result property="nongminxingming" column="nongminxingming"/>
        <result property="xingbie" column="xingbie"/>
        <result property="lianxidianhua" column="lianxidianhua"/>
        <result property="touxiang" column="touxiang"/>
        <result property="money" column="money"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.NongminVO" >
		SELECT * FROM nongmin  nongmin         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.NongminVO" >
		SELECT  nongmin.* FROM nongmin  nongmin 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.NongminView" >

		SELECT  nongmin.* FROM nongmin  nongmin 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.NongminView" >
		SELECT * FROM nongmin  nongmin <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	


</mapper>
